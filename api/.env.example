# CStrike v2 API — Environment Variables
# Copy to .env and configure

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgresql://cstrike:cstrike@localhost:5432/cstrike

# Redis
REDIS_URL=redis://:cstrike@localhost:6379

# CORS
CORS_ORIGINS=http://localhost:3000

# Host tool paths (bind-mounted from Docker host)
HOST_BIN_PATH=/host/usr/bin
HOST_SBIN_PATH=/host/usr/sbin
HOST_LOCAL_BIN_PATH=/host/usr/local/bin
HOST_OPT_PATH=/host/opt

# Logging
LOG_LEVEL=info

# Metrics interval (ms)
METRICS_INTERVAL=2000
