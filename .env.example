    "smbmap", "ldapsearch", "snmpwalk", "onesixtyone", "rpcclient",
    "rustscan",
    "impacket-secretsdump", "impacket-psexec", "impacket-wmiexec",
    "impacket-smbexec", "impacket-GetUserSPNs",
    "testssl", "sslscan", "sslyze",
