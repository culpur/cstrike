# CStrike v2 — Environment Configuration
# Copy to .env and set strong passwords before starting:
#   cp .env.example .env && vim .env
#
# NOTE: AI provider API keys, scan configuration, target scope, and tool
# allowlists are managed through the web UI (Configuration module) or the
# /api/v1/config REST endpoints. These settings are stored in the PostgreSQL
# ConfigEntry table, NOT in this file. This file contains infrastructure
# secrets only.

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=cstrike
POSTGRES_USER=cstrike
POSTGRES_PASSWORD=cstrike

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=cstrike

# ── KasmVNC Remote Browser ─────────────────────────────────
# Password for remote browser access at https://<ip>:6901
KASM_PASSWORD=cstrike

# ── CORS Origins ───────────────────────────────────────────
# Comma-separated origins allowed to connect to the API.
# Add your management IP if accessing from another machine:
#   CORS_ORIGINS=http://localhost:3000,https://cstrike,http://10.0.0.5:3000
CORS_ORIGINS=http://localhost:3000,https://cstrike,https://cstrike.local

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
# Metrics WebSocket emission interval in milliseconds
METRICS_INTERVAL=2000
