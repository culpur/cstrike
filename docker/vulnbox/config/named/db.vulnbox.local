; BIND9 Zone File — vulnbox.local
; Deliberately vulnerable: many subdomains for enumeration tools to discover
$TTL    86400
@       IN      SOA     ns1.vulnbox.local. admin.vulnbox.local. (
                        2024011501 ; Serial
                        3600       ; Refresh
                        1800       ; Retry
                        604800     ; Expire
                        86400      ; Minimum TTL
)

; Name servers
@               IN      NS      ns1.vulnbox.local.
@               IN      NS      ns2.vulnbox.local.

; Mail server
@               IN      MX  10  mail.vulnbox.local.
@               IN      MX  20  smtp.vulnbox.local.

; TXT records (info disclosure)
@               IN      TXT     "v=spf1 ip4:10.10.10.0/24 ~all"
@               IN      TXT     "google-site-verification=FAKEVERIFICATIONSTRING"
_dmarc          IN      TXT     "v=DMARC1; p=none; rua=mailto:admin@vulnbox.local"

; Primary host
@               IN      A       10.10.10.100
ns1             IN      A       10.10.10.100
ns2             IN      A       10.10.10.100

; ──────────────────────────────────────────────────────────────────────
; Subdomains — discoverable by enumeration tools
; ──────────────────────────────────────────────────────────────────────

; Web infrastructure
www             IN      A       10.10.10.100
web             IN      A       10.10.10.100
app             IN      A       10.10.10.100
portal          IN      A       10.10.10.100
cdn             IN      A       10.10.10.100
